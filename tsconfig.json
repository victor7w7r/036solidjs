{
    "compilerOptions": {
        "types": [
            "solid-js"
        ],
        "target": "ESNext",
        "strict": true,
        "sourceMap": true,
        "rootDir": "src",
        "moduleResolution": "node",
        "module": "ESNext",
        "lib": [
            "es6",
            "dom"
        ],
        "jsxImportSource": "solid-js",
        "jsx": "preserve",
        "esModuleInterop": true,
        "allowJs": true
    }
}